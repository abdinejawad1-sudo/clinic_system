# ==========================================
# إعدادات عامة للسيرفر
# ==========================================
PORT=3000
NODE_ENV=development

# ==========================================
# بيانات تسجيل دخول الطبيب للوحة التحكم
# غيّر كلمة المرور هذه قبل النشر الفعلي
# ==========================================
DOCTOR_USERNAME=doctor
DOCTOR_PASSWORD=change_me_123
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_STRING

# ==========================================
# إعدادات ساعات عمل العيادة (لمنع الحجز خارج الدوام)
# ==========================================
CLINIC_OPEN_HOUR=9
CLINIC_CLOSE_HOUR=21
SLOT_DURATION_MINUTES=30

# ==========================================
# بيانات Twilio لإرسال تذكير واتساب تلقائي
# سجّل حساب على https://www.twilio.com/whatsapp
# في وضع Sandbox رقم المرسل الجاهز هو: whatsapp:+14155238886
# ==========================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# كم ساعة قبل الموعد يُرسل التذكير
REMINDER_HOURS_BEFORE=24

# كل كم دقيقة تفحص المهمة المجدولة (cron) المواعيد القادمة
REMINDER_CHECK_CRON=*/15 * * * *
